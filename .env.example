# === Firebase Client (tarayıcı) — Project Settings > General > Your apps (Web) ===
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=proje-adi.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=proje-adi
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=proje-adi.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef

# === Firebase Admin (sadece sunucu) — Service Account JSON'dan alınır ===
# Project Settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=proje-adi
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@proje-adi.iam.gserviceaccount.com
# Tüm anahtarı tek satırda, \n kaçışlarıyla tırnak içinde yapıştır:
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# === Uygulama ayarları ===
ADMIN_PASSWORD=cok-gizli-bir-sifre
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Otomatik fotoğraf temizliği ===
# Fotoğraflar kaç gün sonra otomatik silinsin (varsayılan 7)
NEXT_PUBLIC_RETENTION_DAYS=7
# /api/cleanup endpoint'ini koruyan gizli anahtar (uzun rastgele bir değer üret)
CRON_SECRET=uzun-rastgele-bir-anahtar
